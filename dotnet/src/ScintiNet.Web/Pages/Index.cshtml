                    </div>
                    <div class="p-4">
                        <p class="text-sm text-slate-600 leading-relaxed">@s.Desc</p>
                    </div>
                </div>
            }
        </div>

        <!-- CTA banner -->
        <div class="bg-gradient-to-r from-brand-blue to-brand-green rounded-3xl p-8 md:p-12 text-center text-white">
            <h3 class="text-2xl md:text-3xl font-bold mb-3">Un proche a besoin d'aide ?</h3>
            <p class="text-white/90 text-lg mb-8 max-w-lg mx-auto">Contactez-nous pour une évaluation gratuite et sans engagement. Nous adaptons nos services à chaque situation.</p>
            <div class="flex flex-wrap justify-center gap-4">
                <a href="tel:+14189533284" class="flex items-center gap-2 bg-white text-brand-blue px-6 py-3 rounded-xl font-semibold hover:bg-brand-lime hover:text-slate-900 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    Appeler maintenant
                </a>
                <a href="#contact" class="flex items-center gap-2 border-2 border-white text-white px-6 py-3 rounded-xl font-semibold hover:bg-white/10 transition-colors">
                    Évaluation gratuite
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </a>
            </div>
        </div>
