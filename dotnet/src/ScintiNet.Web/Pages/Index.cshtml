</div>

<!-- ============================================================
     SERVICES
     ============================================================ -->
<section id="services" class="py-20 bg-brand-blue">
    <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-14">
            <span class="text-brand-lime font-semibold text-sm uppercase tracking-wider">Ce que nous faisons</span>
            <h2 class="text-3xl md:text-4xl font-bold text-white mt-2">Nos services d'entretien</h2>
            <p class="text-white/80 mt-3 max-w-xl mx-auto">Des services professionnels adaptés à vos besoins, réalisés par une équipe qualifiée.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @foreach (var svc in services)
            {
                <div id="@svc.Id" class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
                    <div class="relative h-48 overflow-hidden">
                        <img src="@svc.Image" alt="@svc.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                        <span class="absolute bottom-3 left-3 text-2xl">@svc.Icon</span>
                    </div>
                    <div class="p-5">
                        <h3 class="font-bold text-slate-900 text-lg mb-2">@svc.Title</h3>
                        <p class="text-sm text-slate-600 leading-relaxed mb-4">@svc.Desc</p>
                        <a href="#contact" class="text-brand-blue font-semibold text-sm hover:text-brand-green transition-colors flex items-center gap-1">
                            Demander un devis
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                        </a>
