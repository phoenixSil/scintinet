        <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z"/>
    </svg>
</div>

<!-- ============================================================
     SENIORS SECTION
     ============================================================ -->
<section id="aines-soutien" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-14">
            <span class="text-brand-green font-semibold text-sm uppercase tracking-wider">Soins et proximité</span>
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mt-2">Aînés & Soutien <span class="text-brand-blue">à domicile</span></h2>
            <p class="text-slate-600 mt-3 max-w-2xl mx-auto">Des services chaleureux, respectueux et professionnels pour accompagner vos proches âgés dans leur quotidien et préserver leur autonomie.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-12">
            @foreach (var s in seniorServices)
            {
                <div class="group rounded-2xl overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-slate-100">
                    <div class="relative h-44 overflow-hidden">
                        <img src="@s.Image" alt="@s.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
