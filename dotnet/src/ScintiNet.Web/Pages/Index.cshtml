    </svg>
</div>

<!-- ============================================================
     PRICING
     ============================================================ -->
<section id="tarifs" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-14">
            <span class="text-brand-green font-semibold text-sm uppercase tracking-wider">Transparent et simple</span>
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mt-2">Nos forfaits</h2>
            <p class="text-slate-600 mt-3">Choisissez le forfait adapté à vos besoins. Devis personnalisé disponible gratuitement.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
            @foreach (var plan in pricingPlans)
            {
                <div class="@(plan.IsPopular ? "relative bg-brand-blue text-white shadow-2xl scale-105 rounded-3xl" : "bg-slate-50 rounded-2xl shadow-md") p-8 flex flex-col">
                    @if (plan.IsPopular)
                    {
                        <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                            <span class="bg-brand-lime text-slate-900 text-xs font-bold px-4 py-1.5 rounded-full shadow">⭐ Le plus populaire</span>
                        </div>
                    }
                    <h3 class="text-xl font-bold @(plan.IsPopular ? "text-white" : "text-slate-900") mb-1">@plan.Name</h3>
                    <div class="flex items-end gap-1 mt-3 mb-6">
                        <span class="text-4xl font-extrabold @(plan.IsPopular ? "text-brand-lime" : "text-brand-blue")">@plan.Price</span>
                        <span class="text-sm @(plan.IsPopular ? "text-white/70" : "text-slate-500") mb-1">@plan.PriceNote</span>
                    </div>
                    <ul class="space-y-3 mb-8 flex-1">
                        @foreach (var feat in plan.Features)
                        {
                            <li class="flex items-center gap-2 text-sm @(plan.IsPopular ? "text-white/90" : "text-slate-700")">
                                <svg class="w-4 h-4 @(plan.IsPopular ? "text-brand-lime" : "text-brand-green") flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                                @feat
                            </li>
                        }
                    </ul>
                    <a href="#contact" class="@(plan.IsPopular ? "bg-brand-lime text-slate-900 hover:bg-yellow-300" : "bg-brand-blue text-white hover:bg-brand-blue-dark") block text-center py-3 rounded-xl font-semibold transition-colors">
                        @(plan.Price == "Sur devis" ? "Demander un devis" : "Choisir ce forfait")
                    </a>
                </div>
            }
        </div>
        <p class="text-center text-slate-500 text-sm mt-8">Tous les prix s'entendent avant taxes. Des suppléments peuvent s'appliquer selon la superficie.</p>
    </div>
</section>

<!-- ============================================================
     FAQ
     ============================================================ -->
<section id="faq" class="py-20 bg-slate-50">
    <div class="max-w-3xl mx-auto px-4">
        <div class="text-center mb-12">
            <span class="text-brand-blue font-semibold text-sm uppercase tracking-wider">Questions fréquentes</span>
            <h2 class="text-3xl font-bold text-slate-900 mt-2">Tout ce que vous devez savoir</h2>
        </div>
        <div class="space-y-4">
            @foreach (var faq in faqs)
            {
                <div x-data="{ open: false }" class="bg-white rounded-2xl shadow-sm overflow-hidden">
                    <button @@click="open = !open" class="w-full flex items-center justify-between px-6 py-5 text-left font-semibold text-slate-900 hover:text-brand-blue transition-colors">
                        <span>@faq.Q</span>
                        <svg class="w-5 h-5 text-brand-blue flex-shrink-0 transition-transform" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="open" x-transition class="px-6 pb-5 text-slate-600 text-sm leading-relaxed">
                        @faq.A
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ============================================================
     RECENT PROJECTS
     ============================================================ -->
<section id="realisations" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-12">
            <span class="text-brand-green font-semibold text-sm uppercase tracking-wider">Galerie</span>
            <h2 class="text-3xl font-bold text-slate-900 mt-2">Nos récentes <span class="text-brand-blue">réalisations</span></h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
            @foreach (var proj in new[] {
                new { Image = "/images/project-1.png", Title = "Appartement Limoilou", Desc = "Grand ménage complet — 4½ pièces" },
                new { Image = "/images/project-2.png", Title = "Maison Sainte-Foy", Desc = "Entretien bimensuel avec lavage vitres" },
                new { Image = "/images/project-3.png", Title = "Immeuble Beauport", Desc = "Entretien parties communes — 12 logements" },
            })
            {
                <div class="group rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300">
                    <div class="relative h-56 overflow-hidden">
                        <img src="@proj.Image" alt="@proj.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                        <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 group-hover:translate-y-0 transition-transform duration-300 opacity-0 group-hover:opacity-100">
                            <p class="text-white text-sm">@proj.Desc</p>
                        </div>
                    </div>
                    <div class="p-4 bg-slate-50">
                        <h3 class="font-semibold text-slate-900">@proj.Title</h3>
                        <p class="text-sm text-slate-500 mt-0.5">@proj.Desc</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

