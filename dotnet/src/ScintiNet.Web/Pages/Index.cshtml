@page
@model IndexModel
@{
    ViewData["Title"] = "Entretien résidentiel et aide aux aînés à Québec";

    var carouselSlides = new[]
    {
        new { Image = "/images/hero-cleaning.png", Badge = "Services professionnels au Québec", Title = "Entretien et nettoyage <span class='text-brand-green'>résidentiel</span> à Québec", Subtitle = "ScintiNet offre des services complets d'entretien résidentiel, nettoyage spécialisé et services de proximité, pour des espaces propres, sécuritaires et agréables au quotidien.", Cta1 = "Prendre rendez-vous", Cta1Href = "tel:+14189533284", Cta2 = "Demander un devis", Cta2Href = "#contact" },
        new { Image = "/images/carousel-grand-menage.png", Badge = "Grand ménage printanier", Title = "Grand ménage de <span class='text-brand-lime'>printemps</span> dès 149$", Subtitle = "Réservez votre grand ménage printanier et profitez d'un espace impeccable. Nettoyage complet de fond en comble, intérieur et extérieur.", Cta1 = "Réserver maintenant", Cta1Href = "#contact", Cta2 = "Voir les forfaits", Cta2Href = "#tarifs" },
        new { Image = "/images/carousel-lavage-vehicule.png", Badge = "Service mobile", Title = "Lavage de voiture <span class='text-brand-green'>à domicile</span>", Subtitle = "Notre équipe se déplace chez vous pour un lavage intérieur et extérieur professionnel. Plus besoin de vous déplacer !", Cta1 = "Réserver", Cta1Href = "#contact", Cta2 = "Nos tarifs", Cta2Href = "#tarifs" },
        new { Image = "/images/carousel-promo-vendredi.png", Badge = "Offre exclusive", Title = "Vendredi <span class='text-brand-lime'>propre</span> : -15%", Subtitle = "Chaque vendredi, profitez de 15% de rabais sur tous nos services résidentiels. Offre limitée aux réservations faites avant jeudi soir.", Cta1 = "Profiter de l'offre", Cta1Href = "#contact", Cta2 = "Nos services", Cta2Href = "#services" },
        new { Image = "/images/senior-aide-domicile.png", Badge = "Services aux aînés", Title = "Aide à domicile pour <span class='text-brand-green'>vos aînés</span>", Subtitle = "Un service chaleureux et professionnel pour accompagner les personnes âgées dans leur quotidien et maintenir leur autonomie à domicile.", Cta1 = "En savoir plus", Cta1Href = "#aines-soutien", Cta2 = "Contacter", Cta2Href = "#contact" },
        new { Image = "/images/senior-accompagnement.png", Badge = "Accompagnement personalisé", Title = "Accompagnement et <span class='text-brand-lime'>soutien</span> aux aînés", Subtitle = "Notre équipe qualifiée offre une présence rassurante et un soutien complet pour les activités quotidiennes des personnes âgées.", Cta1 = "Découvrir", Cta1Href = "#aines-soutien", Cta2 = "Devis gratuit", Cta2Href = "#contact" },
    };

    var services = new[]
    {
        new { Id = "service-maisons", Image = "/images/service-house.png", Title = "Nettoyage résidentiel", Desc = "Ménage complet de votre maison ou appartement avec des produits écologiques. Nous nous adaptons à vos besoins spécifiques.", Icon = "🏠" },
        new { Id = "service-immeubles", Image = "/images/service-building.png", Title = "Entretien des immeubles", Desc = "Gestion complète de l'entretien des parties communes, corridors, halls d'entrée et espaces extérieurs.", Icon = "🏢" },
        new { Id = "service-vitres", Image = "/images/service-windows.png", Title = "Lavage de vitres", Desc = "Nettoyage professionnel de vos fenêtres intérieures et extérieures pour une vue dégagée et lumineuse.", Icon = "🪟" },
        new { Id = "service-voiture", Image = "/images/service-car.png", Title = "Lavage de voiture", Desc = "Service de lavage automobile à domicile — intérieur, extérieur, cire — sans que vous ayez à vous déplacer.", Icon = "🚗" },
    };

    var seniorServices = new[]
    {
        new { Image = "/images/senior-aide-domicile.png", Title = "Aide à domicile", Desc = "Assistance personnalisée pour les tâches du quotidien à domicile." },
        new { Image = "/images/senior-accompagnement.png", Title = "Accompagnement des aînés", Desc = "Présence bienveillante et accompagnement dans toutes les activités." },
        new { Image = "/images/senior-assistance.png", Title = "Assistance aux personnes âgées", Desc = "Aide spécialisée adaptée aux besoins des personnes âgées." },
        new { Image = "/images/senior-soutien-quotidien.png", Title = "Soutien quotidien", Desc = "Support régulier pour maintenir une bonne qualité de vie." },
        new { Image = "/images/senior-maintien-domicile.png", Title = "Maintien à domicile", Desc = "Services complets pour permettre de rester chez soi en sécurité." },
        new { Image = "/images/senior-aide-domestique.png", Title = "Aide domestique", Desc = "Entretien ménager adapté et préparation des repas." },
        new { Image = "/images/senior-perte-autonomie.png", Title = "Perte d'autonomie", Desc = "Accompagnement spécialisé lors de perte partielle d'autonomie." },
    };

    var pricingPlans = new[]
    {
        new { Name = "Essentiel", Price = "79$", PriceNote = "par visite", IsPopular = false, Features = new[] { "Nettoyage salon + cuisine", "Nettoyage 1 chambre", "Nettoyage 1 salle de bain", "Produits inclus", "Équipe certifiée" } },
        new { Name = "Confort", Price = "129$", PriceNote = "par visite", IsPopular = true, Features = new[] { "Nettoyage complet (4 pièces)", "Toutes les salles de bain", "Lavage des vitres intérieures", "Produits écologiques inclus", "Équipe certifiée", "Rapport de visite" } },
        new { Name = "Prestige", Price = "Sur devis", PriceNote = "personnalisé", IsPopular = false, Features = new[] { "Service entièrement personnalisé", "Fréquence au choix", "Toutes pièces et surfaces", "Vitres intérieures + extérieures", "Produits premium inclus", "Responsable dédié", "Garantie satisfaction" } },
    };

    var faqs = new[]
    {
        new { Q = "Quelle est votre zone de service ?", A = "Nous servons la ville de Québec et ses banlieues : Lévis, Charlesbourg, Beauport, Sainte-Foy et environs." },
        new { Q = "Êtes-vous disponibles les fins de semaine ?", A = "Oui, nous sommes disponibles du lundi au samedi. Pour les urgences mineures, nous pouvons intervenir certains dimanches sur demande." },
        new { Q = "Combien de temps dure un ménage standard ?", A = "En général, 2 à 3 heures pour un appartement de taille moyenne. Le temps peut varier selon la superficie et l'état des lieux." },
        new { Q = "Fournissez-vous le matériel et les produits ?", A = "Oui, tout le matériel et les produits d'entretien sont inclus dans le prix. Nous utilisons des produits écologiques et certifiés sécuritaires." },
        new { Q = "Comment puis-je annuler ou modifier un rendez-vous ?", A = "Vous pouvez annuler ou modifier votre rendez-vous sans frais jusqu'à 24 heures avant le service en nous contactant par téléphone ou courriel." },
        new { Q = "Êtes-vous assurés ?", A = "Oui, ScintiNet est entièrement assurée en responsabilité civile. NEQ 3382027319." },
    };
}

<!-- ============================================================
     HERO CAROUSEL
     ============================================================ -->
<section id="accueil"
    x-data="{
        current: 0,
        total: @carouselSlides.Length,
        paused: false,
        init() {
            setInterval(() => { if (!this.paused) this.next(); }, 5000);
        },
        next() { this.current = (this.current + 1) % this.total; },
        prev() { this.current = (this.current - 1 + this.total) % this.total; }
    }"
    x-cloak
    @@mouseenter="paused = true" @@mouseleave="paused = false"
    class="relative min-h-[90vh] flex items-center overflow-hidden">

    @for (int i = 0; i < carouselSlides.Length; i++)
    {
        var slide = carouselSlides[i];
        <div x-show="current === @i"
             x-transition:enter="transition-opacity duration-700"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition-opacity duration-700"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             class="absolute inset-0 w-full h-full">
            <div class="absolute inset-0 bg-cover bg-center"
                 style="background-image:url('@slide.Image')"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-brand-blue/90 via-brand-blue/70 to-brand-green/40"></div>
        </div>
        <div x-show="current === @i"
             x-transition:enter="transition ease-out duration-700 delay-300"
             x-transition:enter-start="opacity-0 translate-y-6"
             x-transition:enter-end="opacity-100 translate-y-0"
             class="relative z-10 max-w-7xl mx-auto px-4 w-full py-24">
            <span class="inline-block bg-brand-green text-white text-xs font-semibold px-4 py-1.5 rounded-full mb-6">@slide.Badge</span>
            <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-tight mb-6 max-w-3xl" style="text-shadow:0 2px 20px rgba(0,0,0,.3)">@Html.Raw(slide.Title)</h1>
            <p class="text-white/90 text-lg md:text-xl max-w-2xl mb-8 leading-relaxed">@slide.Subtitle</p>
            <div class="flex flex-wrap gap-4">
                <a href="@slide.Cta1Href" class="flex items-center gap-2 bg-white text-brand-blue px-6 py-3.5 rounded-xl font-semibold hover:bg-brand-lime hover:text-slate-900 transition-all duration-200 shadow-lg">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    @slide.Cta1
                </a>
                <a href="@slide.Cta2Href" class="flex items-center gap-2 bg-brand-green text-white px-6 py-3.5 rounded-xl font-semibold hover:bg-brand-green-light transition-all duration-200 shadow-lg">
                    @slide.Cta2
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </a>
            </div>
        </div>
    }

    <!-- Prev / Next arrows -->
    <button @@click="prev()" class="absolute left-4 top-1/2 -translate-y-1/2 z-20 w-12 h-12 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center text-white hover:bg-white/40 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button @@click="next()" class="absolute right-4 top-1/2 -translate-y-1/2 z-20 w-12 h-12 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center text-white hover:bg-white/40 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>

    <!-- Dot indicators -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex gap-2">
        @for (int i = 0; i < carouselSlides.Length; i++)
        {
            <button @@click="current = @i"
                    class="w-2.5 h-2.5 rounded-full transition-all duration-300"
                    :class="current === @i ? 'bg-white w-6' : 'bg-white/50 hover:bg-white/75'"></button>
        }
    </div>
</section>

<!-- ============================================================
     ABOUT / VALUES
     ============================================================ -->
<section id="apropos" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
            <div>
                <span class="text-brand-blue font-semibold text-sm uppercase tracking-wider">Notre entreprise</span>
                <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mt-2 mb-6">L'exigence du propre et net — <span class="text-brand-blue">depuis Québec</span></h2>
                <p class="text-slate-600 leading-relaxed mb-4">ScintiNet est une entreprise québécoise fondée sur des valeurs d'excellence, de professionnalisme et de respect. Nous offrons des services complets d'entretien résidentiel et d'aide à domicile pour les personnes âgées à travers la région de Québec.</p>
                <p class="text-slate-600 leading-relaxed mb-8">Chaque intervention est réalisée par une équipe certifiée, équipée des meilleurs outils et produits écologiques, pour vous garantir un résultat impeccable à chaque visite.</p>
                <div class="flex flex-wrap gap-4">
                    <div class="flex items-center gap-3 bg-blue-50 rounded-xl px-4 py-3">
                        <span class="text-2xl font-bold text-brand-blue">250+</span>
                        <span class="text-sm text-slate-600">Clients satisfaits</span>
                    </div>
                    <div class="flex items-center gap-3 bg-green-50 rounded-xl px-4 py-3">
                        <span class="text-2xl font-bold text-brand-green">5★</span>
                        <span class="text-sm text-slate-600">Note moyenne</span>
                    </div>
                    <div class="flex items-center gap-3 bg-yellow-50 rounded-xl px-4 py-3">
                        <span class="text-2xl font-bold text-brand-lime">100%</span>
                        <span class="text-sm text-slate-600">Produits éco</span>
                    </div>
                </div>
            </div>
            <div class="grid grid-cols-1 gap-4">
                @foreach (var val in new[] {
                    new { Icon = "✅", Title = "Fiabilité", Desc = "Nous respectons nos engagements, horaires et standards de qualité à chaque intervention." },
                    new { Icon = "🌿", Title = "Éco-responsabilité", Desc = "Produits certifiés écologiques, sécuritaires pour votre famille et l'environnement." },
                    new { Icon = "❤️", Title = "Bienveillance", Desc = "Une approche humaine et chaleureuse, particulièrement pour nos services aux aînés." },
                    new { Icon = "🏆", Title = "Excellence", Desc = "Des équipes formées et certifiées pour un résultat irréprochable à chaque visite." },
                    new { Icon = "🔒", Title = "Confiance", Desc = "Entreprise assurée, immatriculée (NEQ 3382027319), équipes vérifiées." },
                })
                {
                    <div class="flex items-start gap-4 bg-slate-50 rounded-xl p-4 hover:bg-blue-50 transition-colors">
                        <span class="text-2xl">@val.Icon</span>
                        <div>
                            <h3 class="font-semibold text-slate-900">@val.Title</h3>
                            <p class="text-sm text-slate-600 mt-0.5">@val.Desc</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- Wave divider -->
<div class="w-full overflow-hidden leading-none bg-white">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-12 fill-brand-blue">
        <path d="M0,0 C360,60 1080,0 1440,60 L1440,60 L0,60 Z"/>
