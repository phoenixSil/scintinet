<!-- ============================================================
     CONTACT FORM
     ============================================================ -->
<section id="contact" class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-12">
            <span class="text-brand-blue font-semibold text-sm uppercase tracking-wider">Nous joindre</span>
            <h2 class="text-3xl font-bold text-slate-900 mt-2">Contactez-nous</h2>
            <p class="text-slate-600 mt-3">Réponse garantie en moins de 24 heures.</p>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 max-w-5xl mx-auto">

            <!-- Contact info -->
            <div class="space-y-6">
                <div class="flex items-start gap-4 bg-white rounded-2xl p-5 shadow-sm">
                    <div class="w-12 h-12 bg-brand-blue/10 rounded-xl flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-slate-900">Téléphone & WhatsApp</h3>
                        <a href="tel:+14189533284" class="text-brand-blue hover:underline">+1 (418) 953-3284</a>
                        <p class="text-xs text-slate-500 mt-1">Lun–Sam 8h–18h</p>
                    </div>
                </div>
                <div class="flex items-start gap-4 bg-white rounded-2xl p-5 shadow-sm">
                    <div class="w-12 h-12 bg-brand-green/10 rounded-xl flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-brand-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-slate-900">Courriel</h3>
                        <a href="mailto:contact@scintinet.com" class="text-brand-blue hover:underline">contact&#64;scintinet.com</a>
                        <p class="text-xs text-slate-500 mt-1">Réponse en 24h</p>
                    </div>
                </div>
                <div class="flex items-start gap-4 bg-white rounded-2xl p-5 shadow-sm">
                    <div class="w-12 h-12 bg-brand-lime/30 rounded-xl flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-slate-900">Adresse</h3>
                        <p class="text-slate-600 text-sm">12 Rue Boucher, App. 8<br/>Québec (QC) G1K 6L8<br/><span class="text-xs text-slate-500">NEQ 3382027319</span></p>
                    </div>
                </div>
            </div>

            <!-- Form -->
            <div class="bg-white rounded-2xl shadow-md p-8">
                @if (Model.FormSuccess == true)
                {
                    <div class="bg-green-50 border border-green-200 rounded-xl p-5 mb-6 text-center">
                        <div class="text-3xl mb-2">✅</div>
                        <h3 class="font-semibold text-green-800">Message envoyé !</h3>
                        <p class="text-green-700 text-sm mt-1">Nous vous répondrons dans les 24 heures.</p>
                    </div>
                }
                @if (Model.FormError != null)
                {
                    <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6">
                        <p class="text-red-700 text-sm">@Model.FormError</p>
                    </div>
                }

                <form method="post" class="space-y-4">
                    <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>
                    @Html.AntiForgeryToken()

                    <div class="grid sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="Input.FullName" class="block text-sm font-medium text-slate-700 mb-1.5">Nom complet *</label>
                            <input asp-for="Input.FullName" placeholder="Marie Tremblay"
                                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent text-sm" />
                            <span asp-validation-for="Input.FullName" class="text-red-600 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="Input.Phone" class="block text-sm font-medium text-slate-700 mb-1.5">Téléphone</label>
                            <input asp-for="Input.Phone" placeholder="+1 (418) 000-0000" type="tel"
                                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent text-sm" />
                        </div>
                    </div>
                    <div>
                        <label asp-for="Input.Email" class="block text-sm font-medium text-slate-700 mb-1.5">Courriel *</label>
                        <input asp-for="Input.Email" placeholder="marie@exemple.com" type="email"
                               class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent text-sm" />
                        <span asp-validation-for="Input.Email" class="text-red-600 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Input.ServiceType" class="block text-sm font-medium text-slate-700 mb-1.5">Service souhaité</label>
                        <select asp-for="Input.ServiceType"
                                class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent text-sm bg-white">
                            <option value="">— Sélectionner un service —</option>
                            <option value="Nettoyage résidentiel">Nettoyage résidentiel</option>
                            <option value="Entretien des immeubles">Entretien des immeubles</option>
                            <option value="Lavage de vitres">Lavage de vitres</option>
                            <option value="Lavage de voiture">Lavage de voiture</option>
                            <option value="Aide à domicile (aînés)">Aide à domicile (aînés)</option>
                            <option value="Accompagnement des aînés">Accompagnement des aînés</option>
                            <option value="Autre">Autre</option>
                        </select>
                    </div>
                    <div>
                        <label asp-for="Input.Subject" class="block text-sm font-medium text-slate-700 mb-1.5">Sujet</label>
                        <input asp-for="Input.Subject" placeholder="Demande de devis"
                               class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent text-sm" />
                    </div>
                    <div>
                        <label asp-for="Input.Body" class="block text-sm font-medium text-slate-700 mb-1.5">Message *</label>
                        <textarea asp-for="Input.Body" rows="4" placeholder="Décrivez votre besoin..."
                                  class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent text-sm resize-none"></textarea>
                        <span asp-validation-for="Input.Body" class="text-red-600 text-xs mt-1 block"></span>
                    </div>
                    <button type="submit"
                            class="w-full bg-brand-blue text-white py-3.5 rounded-xl font-semibold hover:bg-brand-blue-dark transition-colors flex items-center justify-center gap-2 shadow-md">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                        Envoyer le message
                    </button>
                    <p class="text-xs text-slate-400 text-center">En soumettant ce formulaire, vous acceptez notre <a href="/politique-confidentialite" class="underline hover:text-brand-blue">politique de confidentialité</a>.</p>
                </form>
            </div>
        </div>
    </div>
</section>
