<!-- ============================================================
     STATS
     ============================================================ -->
<div class="w-full overflow-hidden leading-none bg-white">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-12 fill-brand-blue">
        <path d="M0,60 C360,0 1080,60 1440,0 L1440,60 L0,60 Z"/>
