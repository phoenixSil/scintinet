# ============================================================
# VARIABLES D'ENVIRONNEMENT - ScintiNet
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# Port sur lequel le serveur écoute (3000 par défaut sur OVH)
PORT=3000

# Environnement
NODE_ENV=production

# ============================================================
# CONFIGURATION EMAIL (pour l'envoi des confirmations)
# ============================================================
# Utilisez les identifiants SMTP de votre fournisseur email
# Exemples de fournisseurs : Gmail, OVH Mail, Outlook, etc.

# Compte Gmail (si vous utilisez Gmail)
# Activez "Mots de passe d'application" dans votre compte Google
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application

# OU - Compte OVH Mail (si vous utilisez le mail OVH)
# SMTP_USER=contact@scintinet.com
# SMTP_PASS=votre-mot-de-passe-email-ovh

# ============================================================
# SESSION (sécurité)
# ============================================================
# Générez une chaîne aléatoire longue (ex: openssl rand -base64 32)
SESSION_SECRET=changez-cette-valeur-par-une-chaine-aleatoire-longue
